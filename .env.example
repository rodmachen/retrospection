DATABASE_URL=postgresql://...    # Supabase connection string (pooler mode)
TODOIST_API_TOKEN=               # Personal API token from Todoist Settings → Integrations
TODOIST_CLIENT_SECRET=           # Webhook HMAC secret from Todoist App Console
API_KEY=                         # Bearer token for REST endpoint auth (generate with: openssl rand -hex 32)
TZ=America/Chicago               # Timezone for daily completion grouping

# Web dashboard auth
APP_PASSWORD=                    # Shared password for the login page
SESSION_SECRET=                  # Cookie signing secret — must be 32+ chars (generate with: openssl rand -hex 32)
INTERNAL_BASE_URL=               # Base URL for server-component → API self-fetch (e.g. https://your-app.vercel.app). Omit on Vercel — VERCEL_URL is used automatically.
